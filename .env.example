# ---------------------------------------------------------------------------
# Supabase (required)
# Uses the modern API keys (Project Settings → API Keys):
#   • Publishable key (sb_publishable_…) — browser-safe, replaces the old anon key
#   • Secret key      (sb_secret_…)      — SERVER ONLY, replaces the old service_role key
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — SERVER ONLY. Never expose to the client / browser.
# Used by lib/supabase/admin.ts for privileged maintenance tasks.
SUPABASE_SECRET_KEY=sb_secret_...

# ---------------------------------------------------------------------------
# AI provider (required for Phase 2 chat only)
# Default provider is OpenAI; swap by editing lib/ai/provider.ts.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Optional: override the default chat model.
OPENAI_MODEL=gpt-4o-mini
